#
# .gitignore
#

# -----------------------------------------------------------------------------
# SECRETS & CONFIGURATION
# -----------------------------------------------------------------------------

# never commit tokens and passwords
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------

# loguru output and general logs
logs/
*.log

# -----------------------------------------------------------------------------
# LOCAL DATA & STATE
# -----------------------------------------------------------------------------

# script state tracking files
chapter.json
services/berserk_checker/chapter.json

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------

# compiled files
__pycache__/
*.py[cod]
*$py.class

# virtual environments
venv/
env/
.venv/

# dev tools cache (mypy, ruff, pytest, etc.)
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# IDE & OS
# -----------------------------------------------------------------------------

# vs code
.vscode/
*.code-workspace

# pycharm / intellij
.idea/

# macos
.DS_Store

# windows
Thumbs.db

# -----------------------------------------------------------------------------
# TRASH
# -----------------------------------------------------------------------------

.old/
